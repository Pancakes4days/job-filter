{
  "delay_between_sources": 2,
  "include_keywords": [
    "python",
    "javascript",
    "typescript",
    "node",
    "react",
    "junior",
    "entry",
    "intern",
    "backend",
    "fullstack",
    "full-stack",
    "devops",
    "cloud",
    "azure",
    "terraform",
    "docker",
    "linux",
    "cybersecurity",
    "security",
    "privacy",
    "data",
    "automation",
    "Artificial Intelligence",
    "LLM",
    "machine learning",
    "scraping"
  ],
  "exclude_keywords": [
    "senior",
    "10+ years",
    "director",
    "staff",
    "lead",
    "principal",
    "manager",
    "9+ years",
    "8+ years",
    "7+ years",
    "6+ years",
    "5+ years",
    "unpaid",
    "commission"
  ],
  "sources": [
    {
      "name": "RemoteOK (all)",
      "type": "remoteok",
      "url": "https://remoteok.com/api",
      "enabled": true
    },
    {
      "name": "WWR - Programming",
      "type": "wwr_rss",
      "url": "https://weworkremotely.com/categories/remote-programming-jobs.rss",
      "enabled": true
    },
    {
      "name": "WWR - DevOps/SysAdmin",
      "type": "wwr_rss",
      "url": "https://weworkremotely.com/categories/remote-devops-sysadmin-jobs.rss",
      "enabled": true
    },
    {
      "name": "WWR - Frontend",
      "type": "wwr_rss",
      "url": "https://weworkremotely.com/categories/remote-front-end-programming-jobs.rss",
      "enabled": true
    },
    {
      "name": "WWR - All Remote Jobs",
      "type": "wwr_rss",
      "url": "https://weworkremotely.com/remote-jobs.rss",
      "enabled": false
    },
    {
      "name": "Remotive",
      "type": "remotive",
      "url": "https://remotive.com/api/remote-jobs",
      "enabled": true
    },
    {
      "name": "Arbeitnow",
      "type": "arbeitnow",
      "url": "https://www.arbeitnow.com/api/job-board-api",
      "pages": 2,
      "enabled": false,
      "_note": "Implemented, but listings skew Europe/Germany — enable if that's of interest"
    },
    {
      "name": "HN Who's Hiring",
      "type": "hn_hiring",
      "url": "https://hn.algolia.com/api/v1/",
      "enabled": true,
      "_note": "Auto-finds the latest monthly thread via Algolia"
    }
  ]
}
