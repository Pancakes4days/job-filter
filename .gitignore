# Python bytecode cache
__pycache__/
*.pyc

# Deployment-specific settings (Tailscale IP, SSH user, paths) — never commit
config/local.json

# Runtime state + outputs (live under data/)
seen_jobs.txt
scraped_jobs.json
*.csv
*.xlsx
*.log
orchestrator_state.json
orchestrator.lock
recruitment_alerts.json

# Legacy laptop-sync artifacts (removed in phase 6; ignored so stale copies on
# an upgraded Pi don't show as untracked). Safe to delete from data/.
pruned_keys.txt
export_mark.txt
export_mark.pending
held_count.txt
job_data/

# Web tracker DB (-wal/-shm are WAL sidecars) + its nightly snapshots
tracker.db
tracker.db-wal
tracker.db-shm
backups/
